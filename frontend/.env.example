# Copy to `.env.local`. Never commit real secrets.
#
# Use http://localhost (not 127.0.0.1) so credentialed requests and cookies match
# the Next.js dev origin (http://localhost:3000) and backend CORS defaults.
#
# Optional: numeric user id sent as X-User-Id on /stream/* (see lib/listening.ts).
# Only honored by the API if backend ENABLE_LEGACY_AUTH=true (default is false).

NEXT_PUBLIC_API_BASE=http://localhost:8000
# NEXT_PUBLIC_LISTENING_USER_ID=1
