# Copy to `.env` in this directory (`backend/`). Never commit real secrets.
# `app/main.py` and `worker.py` load `.env` via python-dotenv (unless disabled below).

# -----------------------------------------------------------------------------
# JWT & session authentication (required for /auth/*)
# -----------------------------------------------------------------------------
#
# Identity: short-lived access JWT = Bearer on protected routes (e.g. GET /auth/me).
# Long-lived refresh JWT = httpOnly cookie (path /auth) for POST /auth/refresh and
# POST /auth/logout only — not used to authenticate GET /auth/me.
#
# REQUIRED: signing key for access and refresh JWTs (minimum 32 characters).
# Generate locally: python3 -c "import secrets; print(secrets.token_urlsafe(40))"
# In production: use a strong secret from your secrets manager; rotate on compromise.
JWT_SECRET_KEY=your-super-secret-key-at-least-32-characters-long

# Algorithm for JWT signing (default HS256). Must match verifiers.
JWT_ALGORITHM=HS256

# Refresh token lifetime in days (integer). Default 30.
JWT_REFRESH_DAYS=30

# Environment label: use `development` or `dev` for local work. Used with ENABLE_DEV_IMPERSONATION.
# Production must NOT use development/dev if you rely on env-gated dev features.
APP_ENV=development

# Fallback if APP_ENV is unset (some code reads APP_ENV or ENV).
ENV=

# Deprecated: when true, stream/listening accepts X-User-Id without Bearer JWT.
# Default is false (production-safe). Do not enable in production; use Bearer only.
# Local scripts that still send X-User-Id may set ENABLE_LEGACY_AUTH=true temporarily.
ENABLE_LEGACY_AUTH=false

# Dev-only: POST /auth/dev/impersonate. Requires APP_ENV (or ENV) development|dev. NEVER true in production.
ENABLE_DEV_IMPERSONATION=true

# HttpOnly refresh cookie: set true when the API is served over HTTPS so Secure cookies work.
AUTH_COOKIE_SECURE=false

# -----------------------------------------------------------------------------
# Algorand (on-chain settlement / signing)
# -----------------------------------------------------------------------------

# 25-word Algorand account mnemonic used to sign settlement transactions.
# Required when running on-chain settlement (`settlement_worker`); keep empty for API-only / no-settlement dev.
ALGOD_MNEMONIC=

# -----------------------------------------------------------------------------
# Algorand / UI (explorer links only — does NOT change Algorand RPC in code)
# -----------------------------------------------------------------------------

# `testnet` or `mainnet`. Controls block-explorer style URLs in the API; Algod URL is fixed in `algorand_client_v2.py`.
NETWORK=testnet

# Max rounds to wait when confirming a settlement transaction (integer string).
SETTLEMENT_TX_WAIT_ROUNDS=1000

# After a V2 payout batch is finalized: if truthy (default), trigger settlement. Use 0 / false / no / off to disable.
AUTO_SETTLEMENT_AFTER_FINALIZE=1

# If truthy (default), run auto-settlement scheduling asynchronously; use 0 / false / no / off for synchronous path.
AUTO_SETTLEMENT_ASYNC=1

# -----------------------------------------------------------------------------
# App environment & safety
# -----------------------------------------------------------------------------

# Set to `true` to expose dev-only HTTP endpoints (see `routes.py`). Leave unset/false in production.
ENABLE_DEV_ENDPOINTS=

# -----------------------------------------------------------------------------
# HTTP / reverse proxy
# -----------------------------------------------------------------------------

# Base URL of the Next.js app (redirects, links). Default in code: http://localhost:3000
NEXT_APP_BASE_URL=http://localhost:3000

# Comma-separated browser origins for CORS when cookies or Authorization are sent.
# Default in code: http://localhost:3000 (that origin is always included if you override this list).
# Use http://localhost:3000 in dev — avoid mixing 127.0.0.1 with localhost (cookies break).
CORS_ORIGINS=http://localhost:3000

# Set to `true` when behind a trusted proxy so client IP can be taken from `X-Forwarded-For`.
TRUST_X_FORWARDED_FOR=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Python logging level name, e.g. DEBUG, INFO, WARNING, ERROR. Default: INFO
LOG_LEVEL=INFO

# Hybrid listening: reject checkpoints if no activity for this many minutes (default 20).
# LISTENING_SESSION_CHECKPOINT_IDLE_MINUTES=20

# -----------------------------------------------------------------------------
# python-dotenv (library behavior)
# -----------------------------------------------------------------------------

# If set to a truthy value per python-dotenv rules, `.env` loading is skipped. Useful for CI/tests that inject env elsewhere.
# PYTHON_DOTENV_DISABLED=
