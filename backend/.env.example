# Copy to `.env` in this directory (`backend/`). Never commit real secrets.
# `app/main.py` and `worker.py` load `.env` via python-dotenv (unless disabled below).

# -----------------------------------------------------------------------------
# Algorand (on-chain settlement / signing)
# -----------------------------------------------------------------------------

# 25-word Algorand account mnemonic used to sign settlement transactions.
# Required when running on-chain settlement (`settlement_worker`); keep empty for API-only / no-settlement dev.
ALGOD_MNEMONIC=

# -----------------------------------------------------------------------------
# Algorand / UI (explorer links only — does NOT change Algod RPC in code)
# -----------------------------------------------------------------------------

# `testnet` or `mainnet`. Controls block-explorer style URLs in the API; Algod URL is fixed in `algorand_client_v2.py`.
NETWORK=testnet

# Max rounds to wait when confirming a settlement transaction (integer string).
SETTLEMENT_TX_WAIT_ROUNDS=1000

# After a V2 payout batch is finalized: if truthy (default), trigger settlement. Use 0 / false / no / off to disable.
AUTO_SETTLEMENT_AFTER_FINALIZE=1

# If truthy (default), run auto-settlement scheduling asynchronously; use 0 / false / no / off for synchronous path.
AUTO_SETTLEMENT_ASYNC=1

# -----------------------------------------------------------------------------
# App environment & safety
# -----------------------------------------------------------------------------

# e.g. `dev`, `development`, `prod`. Some routes check this (with `ENV` as fallback) to allow or deny behavior.
APP_ENV=

# Alternative to APP_ENV; lower precedence when both are set in logic that reads `APP_ENV or ENV`.
ENV=

# Set to `true` to expose dev-only HTTP endpoints (see `routes.py`). Leave unset/false in production.
ENABLE_DEV_ENDPOINTS=

# -----------------------------------------------------------------------------
# HTTP / reverse proxy
# -----------------------------------------------------------------------------

# Base URL of the Next.js app (redirects, links). Default in code: http://localhost:3000
NEXT_APP_BASE_URL=http://localhost:3000

# Set to `true` when behind a trusted proxy so client IP can be taken from `X-Forwarded-For`.
TRUST_X_FORWARDED_FOR=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Python logging level name, e.g. DEBUG, INFO, WARNING, ERROR. Default: INFO
LOG_LEVEL=INFO

# Hybrid listening: reject checkpoints if no activity for this many minutes (default 20).
# LISTENING_SESSION_CHECKPOINT_IDLE_MINUTES=20

# -----------------------------------------------------------------------------
# python-dotenv (library behavior)
# -----------------------------------------------------------------------------

# If set to a truthy value per python-dotenv rules, `.env` loading is skipped. Useful for CI/tests that inject env elsewhere.
# PYTHON_DOTENV_DISABLED=
